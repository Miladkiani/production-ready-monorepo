# =============================================================================
# WEBSITE APPLICATION - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local for local development
# NEVER commit .env.local to version control
# =============================================================================

# -----------------------------------------------------------------------------
# GraphQL API Configuration
# -----------------------------------------------------------------------------
# The backend GraphQL API endpoint
# Local: http://localhost:4000/graphql
# Production: https://api.yourdomain.com/graphql
# Note: This URL is also used to configure Next.js image optimization
# for backend uploads (automatically parsed for hostname, port, protocol)
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------
# Your website's public URL (used for SEO, OG tags, canonical URLs)
# Local: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Node environment
# Options: development | production | test
NODE_ENV=development

# Next.js Port (configured in package.json)
PORT=3000
