{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@repo/typescript-config/next-tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./",
    "rootDir": "",
    "paths": {
      "@admin/*": ["./src/*"],
      "@admin/components/layout/*": ["./src/components/layout/*"],
      "@admin/constants/*": ["./src/constants/*"],
      "@admin/lib": ["./src/lib/index.ts"],
      "@admin/lib/*": ["./src/lib/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    "next.config.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"]
}
