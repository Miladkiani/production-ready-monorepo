# =============================================================================
# ADMIN APPLICATION - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local for local development
# NEVER commit .env.local to version control
# =============================================================================

# -----------------------------------------------------------------------------
# GraphQL API Configuration
# -----------------------------------------------------------------------------
# The backend GraphQL API endpoint
# Development: Use /api/graphql (proxied to localhost:4000/graphql via Next.js rewrites)
# Production: https://yourdomain.com/api/graphql (handled by nginx)
NEXT_PUBLIC_GRAPHQL_URL=/api/graphql

# -----------------------------------------------------------------------------
# REST API Configuration (for file uploads)
# -----------------------------------------------------------------------------
# The backend REST API base URL
# Development: Use /api (proxied to localhost:4000 via Next.js rewrites)
# Production: https://yourdomain.com/api (handled by nginx)
# Note: Used for uploads (/api/upload/*) and images (/api/uploads/*)
NEXT_PUBLIC_API_URL=/api

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# Node environment
# Options: development | production | test
NODE_ENV=development

# Next.js Port (configured in package.json)
PORT=3001

