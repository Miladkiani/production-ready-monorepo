# =============================================================================
# BACKEND APPLICATION - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env for local development
# NEVER commit .env to version control (it's in .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# SQLite Database (file-based, no server required)
# For local development and small-scale production
# File will be created in apps/backend directory
DATABASE_URL="file:./dev.db"

# To migrate to PostgreSQL later, use this format instead:
# DATABASE_URL="postgresql://user:password@localhost:5432/app_db?schema=public"
# PostgreSQL options: Railway, Supabase, Neon, AWS RDS

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# Secret key for signing access tokens (15 min lifespan)
# CRITICAL: Generate strong random strings for production!
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Secret key for signing refresh tokens (7 days lifespan)
# MUST be different from JWT_SECRET for security!
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"

# Refresh token expiration time in milliseconds
# 604800000 = 7 days
# 2592000000 = 30 days
REFRESH_TOKEN_MAX_AGE=604800000

# -----------------------------------------------------------------------------
# Account Security
# -----------------------------------------------------------------------------
# Maximum number of failed login attempts before account lockout
# Recommended: 3-5 attempts
MAX_LOGIN_ATTEMPTS=5

# Duration of account lockout in minutes after max failed attempts
# Recommended: 15-30 minutes
LOCKOUT_DURATION_MINUTES=15

# -----------------------------------------------------------------------------
# Cookie Configuration
# -----------------------------------------------------------------------------
# Enable secure cookies (HTTPS only)
# Local (HTTP): false
# Production (HTTPS): true
COOKIE_SECURE=false

# SameSite cookie attribute for CSRF protection
# Options: strict | lax | none
# For subpath deployments (e.g., admin on /admin): use 'lax'
# Local: lax (allows OAuth redirects and subpaths)
# Production with subpaths: lax (required for admin subpath)
# Production single domain: strict (maximum security)
COOKIE_SAME_SITE=lax

# Optional: Cookie domain for subdomains
# Example: .yourdomain.com (includes api.yourdomain.com, admin.yourdomain.com)
# Leave empty for single domain
# COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Allowed origins for CORS (comma-separated for multiple)
# Admin application URL
CORS_ORIGIN=http://localhost:3001

# Website application URL (if needed for API access)
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------------------------
# Maximum file size in bytes
# 5242880 = 5MB
# 10485760 = 10MB
# 52428800 = 50MB
MAX_FILE_SIZE=5242880

# Upload directory path (relative to project root)
# Local: ./uploads
# Production: Could be AWS S3 bucket, Cloudinary, etc.
UPLOAD_DIR=./uploads

# Public base URL for serving uploaded files
# Local: http://localhost:4000
# Production: https://api.yourdomain.com or CDN URL
PUBLIC_BASE_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Server port
# Default: 4000
PORT=4000

# Node environment
# Options: development | production | test
NODE_ENV=development

# -----------------------------------------------------------------------------
# Seed Data Configuration
# -----------------------------------------------------------------------------
# Admin user credentials for seeding
# IMPORTANT: Change these for production!
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin123!SecurePassword

# -----------------------------------------------------------------------------
# Optional: Monitoring & Analytics
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking (production)
# SENTRY_DSN=

# Application version for tracking
# APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# Optional: Email Configuration (if implementing email features)
# -----------------------------------------------------------------------------
# SMTP Configuration for sending email notifications
# For Gmail: smtp.gmail.com, port 587 (TLS) or 465 (SSL)
# For SendGrid: smtp.sendgrid.net, port 587
# For Mailgun: smtp.mailgun.org, port 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email sender information
# Display name and email address for outgoing emails
SMTP_FROM_NAME=Portfolio Contact
SMTP_FROM_EMAIL=noreply@yourdomain.com

# Admin email address to receive contact form notifications
ADMIN_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# Optional: Redis Configuration (if implementing caching/sessions)
# -----------------------------------------------------------------------------
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
