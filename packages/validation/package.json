{
  "name": "@repo/validation",
  "version": "1.0.0",
  "private": true,
  "description": "Shared Zod validation schemas for forms and API",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "dist-cjs"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json",
    "clean": "rm -rf dist dist-cjs *.tsbuildinfo"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "typescript": "*"
  },
  "dependencies": {
    "zod": "^4.0.14"
  }
}
