# =============================================================================
# Fullstack Turborepo Starter - Production Environment Variables
# =============================================================================
# Copy this to .env and fill in your actual secrets
# Usage: cp .env.example .env
#
# ⚠️ SECURITY: Never commit .env to git!
# =============================================================================
#
# 🎯 ARCHITECTURE:
# - Build-time variables (NEXT_PUBLIC_*) are in docker-compose.yml build args
# - This .env contains ONLY runtime secrets and configuration
# - Changing these = restart container (no rebuild needed)
# - Changing docker-compose.yml build args = rebuild required
# =============================================================================

# =============================================================================
# Database Configuration
# =============================================================================
# SQLite database path (inside container - uses volume for persistence)
DATABASE_URL=file:/data/production.db

# =============================================================================
# JWT Secrets (CRITICAL - CHANGE THESE!)
# =============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHAR_HEX_STRING_EXAMPLE_1234567890abcdef
JWT_REFRESH_SECRET=CHANGE_ME_TO_DIFFERENT_64_CHAR_HEX_STRING_9876543210fedcba

# JWT Token Configuration
JWT_EXPIRATION=7d
REFRESH_TOKEN_MAX_AGE=604800000

# =============================================================================
# Security Settings
# =============================================================================
# Account Protection
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Cookie Security (HTTPS production settings)
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax

# =============================================================================
# GraphQL Configuration
# =============================================================================
# Disable in production for security
GRAPHQL_PLAYGROUND=false
GRAPHQL_INTROSPECTION=false

# =============================================================================
# Admin User (Seed Data)
# =============================================================================
# Used to create initial admin account on first deployment
# ⚠️ CHANGE PASSWORD IMMEDIATELY after first login!
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeThisSecurePassword123!

# Optional: Content Editor account
# CONTENT_EDITOR_EMAIL=editor@yourdomain.com
# CONTENT_EDITOR_PASSWORD=ChangeThisEditorPassword456!

# =============================================================================
# Email Configuration (OPTIONAL)
# =============================================================================
# SMTP settings for contact form and notifications
# Set EMAIL_ENABLED=false if not using email
EMAIL_ENABLED=false

# SMTP Server (Gmail example - use app-specific password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# SMTP Authentication (fill these if EMAIL_ENABLED=true)
SMTP_USER=
SMTP_PASS=

# Email From Information
SMTP_FROM_NAME=App Contact
SMTP_FROM_EMAIL=noreply@yourdomain.com

# =============================================================================
# REMOVED FROM .ENV - NOW IN docker-compose.yml
# =============================================================================
# These are build-time variables (baked into JavaScript bundles):
#
# ❌ NEXT_PUBLIC_API_URL (in docker-compose.yml)
# ❌ NEXT_PUBLIC_GRAPHQL_URL (in docker-compose.yml)
# ❌ NEXT_PUBLIC_SITE_URL (in docker-compose.yml)
# ❌ NEXT_PUBLIC_ADMIN_PATH (in docker-compose.yml)
# ❌ GRAPHQL_URL (hardcoded in docker-compose.yml)
# ❌ API_URL (hardcoded in docker-compose.yml)
# ❌ CORS_ORIGIN (hardcoded in docker-compose.yml)
# ❌ FRONTEND_URL (hardcoded in docker-compose.yml)
# ❌ ADMIN_URL (hardcoded in docker-compose.yml)
# ❌ PUBLIC_BASE_URL (hardcoded in docker-compose.yml)
# ❌ NODE_ENV (hardcoded in docker-compose.yml)
# ❌ PORT (hardcoded in docker-compose.yml)
# ❌ HOSTNAME (hardcoded in docker-compose.yml)
#
# To change domain or URLs:
# 1. Edit docker-compose.yml
# 2. Run: docker compose build
# 3. Run: docker compose up -d
# =============================================================================

